    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "prosemirror-model": "^1.21.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
