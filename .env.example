# Copy this file to .env and adjust as needed.
# Docker Compose reads from .env automatically.

# --- Database ---
# Inside Docker Compose, the api connects to the postgres service by name.
# For bare-metal runs you'd point this at localhost:5432 instead.
POSTGRES_USER=aajia
POSTGRES_PASSWORD=aajia
POSTGRES_DB=aajia
DATABASE_URL=postgres://aajia:aajia@postgres:5432/aajia

# --- Auth placeholder (phase 1 only) ---
# Hardcoded owner id used by the api when stamping/filtering documents.
# This is the single seam to swap out when real auth lands.
PLACEHOLDER_USER_ID=local-dev-user

# --- Ports ---
API_PORT=4000
WEB_PORT=5173

# --- Frontend ---
# The api URL the web app calls. From a browser running on the host,
# this is localhost even though the container talks to the api by service name.
VITE_API_URL=http://localhost:4000
